# 构建产物 / 预编译二进制（保留可下载的 Linux 静态 agent 二进制）
dist/*
!dist/yufu-agent-linux-amd64
!dist/yufu-agent-linux-arm64
*.exe
probe-server
/server/server
probe-agent
agent-*
yufu-agent-darwin-*
yufu-agent-windows-*

# 运行时数据
/data/
*.db
*.db-journal
*.db-wal
*.db-shm

# 本地运行生成的配置（install.sh 会在安装时生成）
configs/*.local.yaml

# 系统 / 编辑器
.DS_Store
*.swp

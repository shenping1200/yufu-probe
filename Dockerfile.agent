# ---- 多阶段构建：客户端 ----
FROM golang:1.25-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /out/probe-agent ./agent

FROM alpine:3.20
RUN apk add --no-cache ca-certificates
WORKDIR /app
COPY --from=build /out/probe-agent /app/probe-agent
ENTRYPOINT ["/app/probe-agent"]
# 运行时通过环境变量传入：SERVER / TOKEN / INTERVAL / IFACE / UUID_FILE
